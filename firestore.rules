rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    // An authenticated user with a verified email. Unverified accounts
    // must not be able to read or write any data.
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin detection is driven by BOTH the Firestore-stored role AND a
    // Firebase Auth custom claim. Custom claims can only be set server-side
    // (Cloud Functions / Admin SDK), so they cannot be forged by a client.
    // The Firestore `role` field is kept in sync for UI convenience but is
    // not the sole source of truth. Hardcoded email allowlists have been
    // removed — rotate admins via custom claims instead.
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.admin == true &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['client', 'admin'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Owners can read their own profile; admins can read all.
      allow read: if isOwner(userId) || isAdmin();

      // A new user may create their own profile, but ONLY as a client.
      // Admin accounts must be promoted server-side via custom claims.
      allow create: if isAuthenticated() &&
                    isValidUser(request.resource.data) &&
                    isOwner(userId) &&
                    request.resource.data.role == 'client';

      // Users can update their own profile but cannot escalate their role.
      // Admins can update any user (including role changes).
      allow update: if isAuthenticated() &&
                    isValidUser(request.resource.data) &&
                    (
                      (isOwner(userId) && request.resource.data.role == resource.data.role) ||
                      isAdmin()
                    );

      // Only admins can delete user documents.
      allow delete: if isAdmin();
    }

    // Deny-by-default for every other collection. Add explicit allow rules
    // as new collections are introduced.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
