# =============================================================================
# Clean Path Credit — environment variable template.
# Copy to `.env.local` for dev; configure the same keys in Vercel Project
# Settings → Environment Variables for Preview + Production.
#
# Variables prefixed with `VITE_` are inlined into the client bundle and are
# therefore public. Everything else must stay server-side (Vercel functions,
# Edge runtimes) — never prefix server secrets with VITE_.
# =============================================================================

# ─── Clerk (client) ─────────────────────────────────────────────────────────
# Clerk Dashboard → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>

# ─── Clerk (server) ───────────────────────────────────────────────────────────
# Secret key — used by /api/me and /api/webhooks/stripe.
CLERK_SECRET_KEY=<your-clerk-secret-key>
# Comma-separated origin allowlist for accepted session tokens (azp claim).
# Defaults to the two production origins if unset. Add your dev origin
# (e.g. http://localhost:3000) to test /api/me locally.
# CLERK_AUTHORIZED_PARTIES=https://cleanpathcredit.com,https://www.cleanpathcredit.com,http://localhost:3000
# Webhook signing secret — Clerk Dashboard → Webhooks → your endpoint.
CLERK_WEBHOOK_SECRET=<your-clerk-webhook-signing-secret>

# ─── Supabase (client) ────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-publishable-or-anon-key>

# ─── Supabase (server) ────────────────────────────────────────────────────────
# Must NOT be prefixed with VITE_ — service-role key must never reach the
# client bundle. Used by /api/me and /api/webhooks/*.
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ─── Stripe (client) ──────────────────────────────────────────────────────────
# Publishable key + Buy Button IDs are safe to expose, but are env-driven so
# prod/preview can swap Stripe accounts (test mode) without a code change.
# PlanGate falls back to a plain CTA link when any of these are unset.
VITE_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
# Stripe Dashboard → Buy Buttons → each button's ID. Note: Buy Button IDs are
# regenerated whenever a button is rewritten — keep these in sync.
VITE_STRIPE_BUY_BUTTON_DIY=<your-diy-buy-button-id>
VITE_STRIPE_BUY_BUTTON_STANDARD=<your-standard-buy-button-id>
VITE_STRIPE_BUY_BUTTON_PREMIUM=<your-premium-buy-button-id>

# ─── Stripe (server) ──────────────────────────────────────────────────────────
# Used by /api/webhooks/stripe.
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-signing-secret>
# Stripe Price ID → plan mapping (CSV, e.g. price_abc=diy,price_def=standard,
# price_ghi=premium). If unset, /api/webhooks/stripe falls back to amount-based
# matching. Find Price IDs in Stripe Dashboard → Products → each product's
# "Pricing" section. These are stable across Buy Button rewrites.
STRIPE_PRICE_PLAN_MAP=

# ─── Admin seeding ────────────────────────────────────────────────────────────
# When a Clerk user is created with this email the Clerk webhook will seed
# their Supabase profile with role='admin'.
ADMIN_EMAIL=you@cleanpathcredit.com

# ─── Lead webhook ─────────────────────────────────────────────────────────────
# Client-side form POSTs to this path, which must be an internal proxy (never
# the raw GHL webhook — that would leak the URL to every visitor).
VITE_LEAD_WEBHOOK_URL=/api/lead

# ─── GoHighLevel (server) ─────────────────────────────────────────────────────
# Primary delivery path for /api/lead: the official v2 Contacts API via a
# Private Integration Token. GHL → Settings → Private Integrations →
# create integration → copy the "pit-..." token + the location's ID from
# Settings → Business Profile. Required scopes: Contacts (read+write),
# Conversations (read), Locations (read).
GHL_PRIVATE_INTEGRATION_TOKEN=pit-<your-private-integration-token>
GHL_LOCATION_ID=<your-location-id>

# Legacy inbound webhook URL — kept as CO-SEND so existing workflow
# automations (SMS drips, pipeline stage moves, etc.) triggered by the
# "Inbound Webhook" node keep firing. Also the FALLBACK when the PIT route
# fails or is unset. Used by the Stripe webhook for purchase notifications.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/<your-hook-id>

# ─── OpenRouter (admin AI features) ───────────────────────────────────────────
# Powers the "Draft follow-up email" button on each lead row in the admin
# dashboard. Get a key at https://openrouter.ai/keys. Default model is
# anthropic/claude-3.5-haiku (cheap + fast + coherent for short copy).
# Override OPENROUTER_MODEL to any slug from https://openrouter.ai/models.
OPENROUTER_API_KEY=<your-openrouter-api-key>
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# ─── Cloudflare Turnstile (C-4 bot protection) ────────────────────────────────
# Public site key is safe to expose; secret lives server-side only on /api/lead.
# Cloudflare Dashboard → Turnstile → your widget → Site Key.
VITE_TURNSTILE_SITE_KEY=<your-turnstile-site-key>
TURNSTILE_SECRET_KEY=<your-turnstile-secret-key>
