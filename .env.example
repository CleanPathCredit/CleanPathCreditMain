# ─── Clerk (client) ──────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase (client) ───────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx   # or legacy eyJ... anon key

# ─── Lead webhook (proxy URL, NOT the raw third-party endpoint) ──────────────
# Point this at your own backend/Edge Function that forwards to the CRM.
VITE_LEAD_WEBHOOK_URL=/api/lead

# ─── Stripe (client — publishable key, safe to ship to browser) ──────────────
# Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server-side (Vercel env vars — do NOT prefix with VITE_) ────────────────
# Used by /api/me, /api/webhooks/clerk, /api/admin/delete-client, etc.

# Clerk Backend API key — needed to delete users via the admin dashboard.
# Get from https://dashboard.clerk.com → API Keys → Secret Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Webhooks signing secret — for /api/webhooks/clerk
# Get from https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service-role key — bypasses RLS, server-side only
# Get from https://supabase.com/dashboard → your project → Settings → API → service_role
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx

# Email of the account that should be auto-promoted to role=admin when its
# Clerk user is created. Used by the Clerk webhook.
ADMIN_EMAIL=you@example.com
